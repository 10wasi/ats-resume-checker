# Public site URL for SEO (sitemap, robots, metadataBase). No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Free tier — limits reset at midnight UTC (in-memory per server; use Redis/DB in production).
# FREE_ANALYZES_PER_DAY=3
# FREE_EXTRACTS_PER_DAY=15
# Local testing: set to "true" to skip limits
# DISABLE_USAGE_LIMITS=false

# MVP: POST /api/billing/activate-pro with { "secret": "<this value>" } sets Pro cookie (httpOnly)
# PRO_ACTIVATION_SECRET=

# Stripe (optional — wire checkout + webhooks when ready)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=

# Groq (OpenAI-compatible API) — preferred when set. Get a key at https://console.groq.com
# GROQ_API_KEY=gsk_...

# OpenAI — used only if GROQ_API_KEY is not set
# OPENAI_API_KEY=sk_...
