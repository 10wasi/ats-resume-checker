# Public site URL for SEO (sitemap, robots, metadataBase). No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# AI resume narrative (at least one required on Vercel for full LLM output — otherwise scoring still runs via the rules engine).
# Prefer Groq (OpenAI-compatible): https://console.groq.com — add key in Vercel → Settings → Environment Variables.
# GROQ_API_KEY=gsk_...

# OpenAI — used when GROQ_API_KEY is not set
# OPENAI_API_KEY=sk_...
# FREE_ANALYZES_PER_DAY=3
# FREE_EXTRACTS_PER_DAY=15
# Local testing: set to "true" to skip limits
# DISABLE_USAGE_LIMITS=false

# MVP: POST /api/billing/activate-pro with { "secret": "<this value>" } sets Pro cookie (httpOnly)
# PRO_ACTIVATION_SECRET=

# Stripe (optional — wire checkout + webhooks when ready)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
