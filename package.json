{
  "name": "ai-resume-ats-checker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "next dev -H 0.0.0.0 -p 3847",
    "dev:3000": "next dev -H 0.0.0.0 -p 3000",
    "dev:3080": "next dev -H 0.0.0.0 -p 3080",
    "dev:fresh": "npm run clean && next dev -H 0.0.0.0 -p 3847",
    "dev:turbo": "next dev -H 0.0.0.0 -p 3847 --turbo",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3847",
    "serve": "npm run build && next start -H 0.0.0.0 -p 3847",
    "serve:fresh": "npm run clean && npm run build && next start -H 0.0.0.0 -p 3847",
    "open:local": "start http://localhost:3847",
    "open:3000": "start http://localhost:3000",
    "open:3080": "start http://localhost:3080",
    "ping:local": "node scripts/ping-local.mjs",
    "ping:routes": "node scripts/ping-local.mjs",
    "lint": "next lint"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "mammoth": "^1.8.0",
    "next": "14.2.18",
    "openai": "^6.35.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
